<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>720</width>
    <height>380</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Транспортный справочник</string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout">

    <!-- Файл с данными -->
    <item>
     <widget class="QGroupBox" name="groupBoxInput">
      <property name="title">
       <string>Файл с данными</string>
      </property>
      <layout class="QHBoxLayout">
       <item>
        <widget class="QLineEdit" name="inputFileLineEdit">
         <property name="readOnly">
          <bool>true</bool>
         </property>
         <property name="placeholderText">
          <string>Выберите JSON-файл с базой...</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPushButton" name="browseInputButton">
         <property name="text">
          <string>Обзор...</string>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>

    <!-- Параметры запроса -->
    <item>
     <widget class="QGroupBox" name="groupBoxRequest">
      <property name="title">
       <string>Параметры запроса</string>
      </property>
      <layout class="QFormLayout">

       <item row="0" column="0">
        <widget class="QLabel">
         <property name="text">
          <string>Тип запроса:</string>
         </property>
        </widget>
       </item>
       <item row="0" column="1">
        <widget class="QComboBox" name="requestTypeComboBox">
         <item><property name="text"><string>Stop</string></property></item>
         <item><property name="text"><string>Bus</string></property></item>
         <item><property name="text"><string>Map</string></property></item>
        </widget>
       </item>

       <item row="1" column="0">
        <widget class="QLabel">
         <property name="text">
          <string>Название:</string>
         </property>
        </widget>
       </item>
       <item row="1" column="1">
        <widget class="QLineEdit" name="requestNameLineEdit">
         <property name="placeholderText">
          <string>Введите название остановки или маршрута</string>
         </property>
        </widget>
       </item>

      </layout>
     </widget>
    </item>

    <!-- Выходной файл -->
    <item>
     <widget class="QGroupBox" name="groupBoxOutput">
      <property name="title">
       <string>Выходной файл</string>
      </property>
      <layout class="QHBoxLayout">
       <item>
        <widget class="QLineEdit" name="outputFileLineEdit">
         <property name="placeholderText">
          <string>Введите имя файла (например result.json или map.svg)</string>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>

    <!-- Действия -->
    <item>
     <widget class="QGroupBox" name="groupBoxActions">
      <property name="title">
       <string>Действия</string>
      </property>
      <layout class="QHBoxLayout">

       <item>
        <widget class="QPushButton" name="runButton">
         <property name="text">
          <string>Выполнить запрос</string>
         </property>
        </widget>
       </item>

       <item>
        <widget class="QPushButton" name="clearButton">
         <property name="text">
          <string>Очистить базу</string>
         </property>
        </widget>
       </item>

      </layout>
     </widget>
    </item>

   </layout>
  </widget>

  <widget class="QMenuBar" name="menubar"/>
  <widget class="QStatusBar" name="statusbar"/>

